# The app runs with zero secrets. Every seam degrades gracefully:
#   - catalog  -> public Pokemon TCG API (no key needed)
#   - auth/db  -> a setup screen appears until Firebase is configured
#   - email    -> invite link is shown in the UI ("email not configured")
#   - logging  -> structured console output
# Fill in a seam's block to activate its production provider.

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Absolute base URL used to build invite links. Defaults to the request origin
# when unset, so local development needs nothing here.
APP_BASE_URL=

# ----------------------------------------------------------------------------
# auth + db seam: Firebase
# ----------------------------------------------------------------------------
# Client config is public by design (safe to expose to the browser).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Admin credentials are server only. The private key contains newlines; paste it
# with the newlines escaped as \n and it is un-escaped at load.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Point the app at the local Firestore/Auth emulators (used by integration tests
# and local development without a real project). Leave unset in production.
FIREBASE_AUTH_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=

# ----------------------------------------------------------------------------
# email seam: SMTP (Gmail)
# ----------------------------------------------------------------------------
# Relays through a mailbox you own, so it delivers to any recipient with no
# custom domain or DNS. For Gmail: enable 2-Step Verification, then create an
# App Password (https://myaccount.google.com/apppasswords) and use it as EMAIL_PASS.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=you@gmail.com
EMAIL_PASS=
EMAIL_FROM=you@gmail.com

# ----------------------------------------------------------------------------
# observability seam: Google Cloud Logging
# ----------------------------------------------------------------------------
# Reuses the Firebase service account. When absent, logs go to the console.
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
GCP_PRIVATE_KEY=
